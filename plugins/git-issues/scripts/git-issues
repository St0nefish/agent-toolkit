#!/usr/bin/env bash
# git-issues — unified issue + PR wrapper for GitHub and Gitea.
# Detects the upstream from the git remote URL and routes to the correct CLI
# (gh for GitHub, tea for Gitea), so callers never need to know the platform.
#
# Usage:
#   git-issues list [--limit N]          list open issues (JSON, with platform header)
#   git-issues show <number>             show full issue details (JSON)
#   git-issues pr [--title T]            open a pull request
#              [--description D]
#              [--head H] [--base B]

set -euo pipefail

die() { echo "git-issues: $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------
detect_platform() {
  local remote_url
  remote_url=$(git remote get-url origin 2>/dev/null) \
    || die "no git remote 'origin' found"

  if echo "$remote_url" | grep -qi "github\.com"; then
    echo "github"
  else
    echo "gitea"
  fi
}

PLATFORM=$(detect_platform)

case "$PLATFORM" in
  github) CLI=gh   ;;
  gitea)  CLI=tea  ;;
esac

command -v "$CLI" >/dev/null 2>&1 \
  || die "$CLI not found — install it and authenticate before using git-issues"

# ---------------------------------------------------------------------------
# Command routing
# ---------------------------------------------------------------------------
cmd="${1:-}"
shift || true

case "$cmd" in
  list)
    echo "# platform=${PLATFORM} cli=${CLI}"
    case "$PLATFORM" in
      github)
        gh issue list \
          --json number,title,body,state,labels,milestone,comments,createdAt \
          "$@"
        ;;
      gitea)
        tea issues list \
          --fields index,title,body,state,labels,milestone,comments,created \
          --output json "$@" 2>/dev/null \
          || tea issues list \
               --fields index,title,body,state,labels,milestone,comments,created \
               "$@"
        ;;
    esac
    ;;

  show)
    [[ $# -ge 1 ]] || die "usage: git-issues show <number> [flags]"
    num="$1"; shift
    case "$PLATFORM" in
      github)
        gh issue view "$num" \
          --json number,title,body,state,labels,milestone,comments "$@"
        ;;
      gitea)
        tea issues "$@" "$num" --output json 2>/dev/null \
          || tea issues "$@" "$num"
        ;;
    esac
    ;;

  pr)
    # Accept a unified flag set; translate --description to --body for GitHub.
    # Passes all remaining args through after translation.
    args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --description)
          shift
          case "$PLATFORM" in
            github) args+=(--body "$1") ;;
            gitea)  args+=(--description "$1") ;;
          esac
          ;;
        *)
          args+=("$1")
          ;;
      esac
      shift
    done
    case "$PLATFORM" in
      github) gh pr create "${args[@]}" ;;
      gitea)  tea pr create "${args[@]}" ;;
    esac
    ;;

  *)
    die "usage: git-issues {list|show|pr} [args...]"
    ;;
esac
