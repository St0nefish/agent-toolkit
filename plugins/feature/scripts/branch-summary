#!/usr/bin/env bash
# branch-summary - Minimal git context for branch-vs-base summaries
# Exit codes: 0 success, 1 bad usage

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: branch-summary [directory]

Emit only the git information needed to summarize current work against
main/master (with origin/* fallback), including:
- branch/ref detection
- committed changes vs base
- staged/unstaged/untracked changes
- zero-context diffs for concise detail extraction
EOF
    exit 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

if [[ $# -gt 1 ]]; then
    usage
fi

dir="${1:-.}"
cd "$dir"

gitq() {
    git -c core.quotepath=false "$@"
}

if ! gitq rev-parse --git-dir >/dev/null 2>&1; then
    echo "=== REPO ==="
    echo "is_git_repo: false"
    echo "reason: not a git repository"
    exit 0
fi

head_branch="$(gitq symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
head_sha="$(gitq rev-parse --short HEAD 2>/dev/null || echo "unknown")"

if [[ -n "$head_branch" ]]; then
    echo "=== HEAD ==="
    echo "on_branch: true"
    echo "branch: $head_branch"
else
    echo "=== HEAD ==="
    echo "on_branch: false"
    echo "detached_at: $head_sha"
fi

base_ref=""
for candidate in "main" "master" "origin/main" "origin/master"; do
    if gitq rev-parse --verify "$candidate" >/dev/null 2>&1; then
        base_ref="$candidate"
        break
    fi
done

echo ""
echo "=== BASE ==="
if [[ -z "$base_ref" ]]; then
    echo "detected: false"
    echo "reason: neither main/master nor origin/main/origin/master exists"
else
    echo "detected: true"
    echo "ref: $base_ref"
    ahead="$(gitq rev-list --count "$base_ref..HEAD" 2>/dev/null || echo 0)"
    behind="$(gitq rev-list --count "HEAD..$base_ref" 2>/dev/null || echo 0)"
    echo "ahead: $ahead"
    echo "behind: $behind"
fi

if [[ -n "$base_ref" ]]; then
    committed_files="$(gitq diff --name-status --find-renames "$base_ref...HEAD" 2>/dev/null || true)"
    committed_numstat="$(gitq diff --numstat --find-renames "$base_ref...HEAD" 2>/dev/null || true)"
    committed_diff="$(gitq diff --no-color --minimal --unified=0 --find-renames "$base_ref...HEAD" 2>/dev/null || true)"

    if [[ -n "$committed_files" ]]; then
        echo ""
        echo "=== COMMITTED FILES ==="
        echo "$committed_files"
    fi
    if [[ -n "$committed_numstat" ]]; then
        echo ""
        echo "=== COMMITTED NUMSTAT ==="
        echo "$committed_numstat"
    fi
    if [[ -n "$committed_diff" ]]; then
        echo ""
        echo "=== COMMITTED DIFF ==="
        echo "$committed_diff"
    fi
fi

staged_files="$(gitq diff --name-status --cached --find-renames 2>/dev/null || true)"
staged_numstat="$(gitq diff --numstat --cached --find-renames 2>/dev/null || true)"
staged_diff="$(gitq diff --no-color --minimal --unified=0 --cached --find-renames 2>/dev/null || true)"

unstaged_files="$(gitq diff --name-status --find-renames 2>/dev/null || true)"
unstaged_numstat="$(gitq diff --numstat --find-renames 2>/dev/null || true)"
unstaged_diff="$(gitq diff --no-color --minimal --unified=0 --find-renames 2>/dev/null || true)"

untracked_files="$(gitq ls-files --others --exclude-standard 2>/dev/null || true)"

if [[ -n "$staged_files" ]]; then
    echo ""
    echo "=== STAGED FILES ==="
    echo "$staged_files"
fi
if [[ -n "$staged_numstat" ]]; then
    echo ""
    echo "=== STAGED NUMSTAT ==="
    echo "$staged_numstat"
fi
if [[ -n "$staged_diff" ]]; then
    echo ""
    echo "=== STAGED DIFF ==="
    echo "$staged_diff"
fi

if [[ -n "$unstaged_files" ]]; then
    echo ""
    echo "=== UNSTAGED FILES ==="
    echo "$unstaged_files"
fi
if [[ -n "$unstaged_numstat" ]]; then
    echo ""
    echo "=== UNSTAGED NUMSTAT ==="
    echo "$unstaged_numstat"
fi
if [[ -n "$unstaged_diff" ]]; then
    echo ""
    echo "=== UNSTAGED DIFF ==="
    echo "$unstaged_diff"
fi

if [[ -n "$untracked_files" ]]; then
    echo ""
    echo "=== UNTRACKED FILES ==="
    echo "$untracked_files"
fi

if [[ -z "$base_ref" && -z "$staged_files" && -z "$unstaged_files" && -z "$untracked_files" ]]; then
    echo ""
    echo "=== CHANGES ==="
    echo "none_detected: true"
fi

if [[ -n "$base_ref" && -z "${committed_files:-}" && -z "$staged_files" && -z "$unstaged_files" && -z "$untracked_files" ]]; then
    echo ""
    echo "=== CHANGES ==="
    echo "none_detected: true"
fi
